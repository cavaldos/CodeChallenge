{
  "compilerOptions": {
    /* Basic Options */
    "target": "ES2022",
    "module": "NodeNext",
    "outDir": "dist",
    "rootDir": "./src",
    "allowUmdGlobalAccess": true,
    "skipLibCheck": true,
    /* Strict Type-Checking Options */
    "strict": false,
    "noImplicitAny": true,
    "noImplicitThis": true,
    /* Additional Checks */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    /* Module Resolution Options */
    "moduleResolution": "nodenext",
    "typeRoots": [
      "node_modules/@types",
      "types"
    ],
    "esModuleInterop": true,
    /* Advanced Options */
    "forceConsistentCasingInFileNames": true
  },
  "ts-node": {
    "esm": true
  },
  "exclude": [
    "node_modules",
    "tests",
    "types",
    "coverage",
    "__test__"
  ]
}