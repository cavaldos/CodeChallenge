{
  "name": "server",
  "version": "2.1.0",
  "description": "Typescript Project Template for Back End Development",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "ts:start": "ts-node src/server.ts",
    "dev": "tsnd --respawn --transpile-only --exit-child src/server.ts",
    "debug": "tsnd --respawn --transpile-only --exit-child --debug src/server.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "engines": {
    "node": ">=18.12.1",
    "npm": ">=8.19.2",
    "yarn": ">=1.22.19"
  },
  "license": "MIT",
  "dependencies": {
    "@grpc/grpc-js": "^1.10.1",
    "ansi-colors": "^4.1.3",
    "chalk": "^5.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "5.1.0",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "portfinder": "^1.0.32",
    "sequelize": "^6.37.8",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.13",
    "@types/jsonwebtoken": "^8.5.8",
    "@types/morgan": "^1.9.9",
    "@types/node": "^18.0.3",
    "@types/pg": "^8.20.0",
    "@types/sequelize": "^4.28.20",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "morgan": "^1.10.0",
    "ts-node": "^10.8.2",
    "ts-node-dev": "^2.0.0",
    "tslib": "^2.4.0",
    "tsx": "^4.21.0",
    "typescript": "^4.9.3"
  }
}
